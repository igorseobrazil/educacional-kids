rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tabela de lookup de convites — qualquer usuário autenticado pode ler
    // (só tem child_id, sem dados sensíveis)
    match /invite_codes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /children/{childId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.guardians;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.guardians;

      // Permite adicionar-se como guardian via código de convite
      // (só pode adicionar ao array guardians, sem alterar outros campos)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guardians'])
        && request.resource.data.guardians.hasAll(resource.data.guardians);

      match /memory_states/{questionId} {
        allow read, write, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.guardians;
      }

      match /session_logs/{logId} {
        allow read, write, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.guardians;
      }
    }
  }
}

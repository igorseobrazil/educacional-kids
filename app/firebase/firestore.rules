rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil do responsável — só o próprio usuário acessa
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Filhos — qualquer responsável vinculado (guardians[]) pode ler e escrever
    match /children/{childId} {
      // Leitura e escrita: usuário precisa estar na lista guardians
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.guardians;

      // Criação: usuário autenticado pode criar, desde que se inclua como guardian
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.guardians;

      // Estados de memória do FSRS
      match /memory_states/{questionId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.guardians;
      }

      // Logs de sessão
      match /session_logs/{logId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.guardians;
      }
    }
  }
}
